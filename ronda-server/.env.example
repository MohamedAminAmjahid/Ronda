# Port d'écoute (Railway fournit PORT automatiquement)
PORT=2567

# Chemin du fichier SQLite (persistant). Sur Railway, monter un volume et pointer ici.
DATABASE_PATH=./data/ronda.db

# Origines autorisées pour CORS (séparées par des virgules). * en dev.
CORS_ORIGIN=*

# Délai de reconnexion autorisé après déconnexion (secondes)
RECONNECT_SECONDS=60
