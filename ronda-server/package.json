{
  "name": "ronda-server",
  "version": "1.0.0",
  "description": "Serveur multijoueur autoritaire pour la Ronda marocaine (Colyseus).",
  "private": true,
  "main": "build/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.0",
    "colyseus": "^0.16.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "firebase-admin": "11.11.1",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
